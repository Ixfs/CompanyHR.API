{
    "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"

  "Jwt": {
    "Key": "your_super_secret_key_here_at_least_32_chars",
