{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=CompanyHR;Username=postgres;Password=password;Port=5432",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "Key": "your_super_secret_key_here_at_least_32_chars_long",
    "Issuer": "CompanyHR",
    "Audience": "CompanyHRUsers",
    "AccessTokenExpireDays": 1,
    "RefreshTokenExpireDays": 7
  },
  "Email": {
    "SenderName": "Company HR",
    "SenderEmail": "noreply@company.com",
    "SmtpServer": "smtp.gmail.com",
    "SmtpPort": 587,
    "SmtpUsername": "your-email@gmail.com",
    "SmtpPassword": "your-app-password"
  },
  "ApiVersioning": {
    "DefaultApiVersion": "1.0",
    "AssumeDefaultVersionWhenUnspecified": true,
    "ReportApiVersions": true
  },
  "CacheSettings": {
    "DefaultExpirationMinutes": 10,
    "SlidingExpirationMinutes": 5
  }
}
